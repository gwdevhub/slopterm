# Builds and runs slopterm's backend (with the React UI embedded) in a container - for
# local dev/testing only, see the "Testing in Docker" section of README.md. This is NOT
# how the app is meant to be used for real: there's no tray icon, no app-mode browser
# window (see server/BrowserLauncher.cs), and PWA install doesn't apply inside a
# container - it only exercises the same HTTP/WebSocket surface the e2e suite drives.

FROM node:20-slim AS web-build
WORKDIR /src/web
COPY web/package.json web/package-lock.json ./
RUN npm ci
COPY web/ ./
RUN npm run build

FROM mcr.microsoft.com/dotnet/sdk:8.0 AS server-build
WORKDIR /src/server
COPY server/*.csproj ./
RUN dotnet restore -r linux-x64
COPY server/ ./
COPY --from=web-build /src/server/wwwroot ./wwwroot
RUN dotnet publish -c Release -r linux-x64 -o /out

# runtime-deps (not the full sdk/aspnet runtime image) is enough - the publish above is
# self-contained and bundles its own .NET runtime (see Slopterm.Server.csproj).
FROM mcr.microsoft.com/dotnet/runtime-deps:8.0
WORKDIR /app
COPY --from=server-build /out/Slopterm.Server ./

# Default vault location (see AppPaths.cs) is a per-OS user profile directory that
# wouldn't survive a container being recreated - point it at a path meant to be mounted
# as a volume instead, if you want vault data to persist across `docker run`s.
ENV SLOPTERM_VAULT_DIR=/data
VOLUME /data

EXPOSE 51823
ENTRYPOINT ["./Slopterm.Server"]
